# normalize line endings for text files, regardless of OS
* text=auto eol=lf

# C++ source
*.cpp text diff=cpp
*.hpp text diff=cpp

# docs / config
*.md text
.editorconfig text
.gitattributes text
.gitignore text

# shell / scripts
*.sh text eol=lf
*.lua text eol=lf

# binary sample files used for testing the parser
*.bin binary
*.elf binary
*.exe binary
*.dll binary
*.so binary
